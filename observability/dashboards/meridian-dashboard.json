{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Meridian Platform — on-call dashboard. Gateway · Model Server · RAG Service · SLOs · GPU/KV-cache.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🌐 Gateway — Rate / Errors / Duration",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(gateway_requests_total[1m]))",
          "legendFormat": "total rps",
          "refId": "A"
        },
        {
          "expr": "sum(rate(gateway_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx rps",
          "refId": "B"
        }
      ],
      "title": "Gateway — Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percentunit",
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.005 }
            ]
          }
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(gateway_requests_total{status=~\"5..\"}[5m])) / sum(rate(gateway_requests_total[5m]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ],
      "title": "Gateway — Error Rate (SLO < 0.5%)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 1.2 }
            ]
          }
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gateway_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gateway_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(gateway_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Gateway — Latency p50/p95/p99 (SLO p95 ≤ 1.2s)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "id": 101,
      "title": "🤖 Model Server — Throughput · Latency · GPU/KV-Cache",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 9 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(model_requests_total[1m])) by (status)",
          "legendFormat": "status={{status}}",
          "refId": "A"
        }
      ],
      "title": "Model Server — Request Rate by Status",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 9 },
      "id": 5,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(model_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(model_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "title": "Model Server — Latency p50/p95",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      },
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 9 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "showThresholdLabels": true, "showThresholdMarkers": true },
      "targets": [
        {
          "expr": "model_gpu_utilization_ratio",
          "legendFormat": "GPU Util",
          "refId": "A"
        },
        {
          "expr": "model_kv_cache_usage_ratio",
          "legendFormat": "KV-Cache",
          "refId": "B"
        }
      ],
      "title": "GPU Util & KV-Cache Usage",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 9 },
      "id": 7,
      "targets": [
        {
          "expr": "model_requests_in_flight",
          "legendFormat": "in-flight",
          "refId": "A"
        },
        {
          "expr": "model_queue_depth",
          "legendFormat": "queue depth",
          "refId": "B"
        }
      ],
      "title": "Model Server — In-flight & Queue Depth",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "cps"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 16 },
      "id": 8,
      "targets": [
        {
          "expr": "sum(rate(model_tokens_generated_total[1m]))",
          "legendFormat": "tokens/s",
          "refId": "A"
        }
      ],
      "title": "Model Server — Tokens Generated per Second",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 102,
      "title": "🔍 RAG Service — Retrieval · Context · Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 24 },
      "id": 9,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_retrieval_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "retrieval p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_retrieval_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "retrieval p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "total RAG p95",
          "refId": "C"
        }
      ],
      "title": "RAG — Retrieval vs Total Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 24 },
      "id": 10,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_context_chars_bucket[5m])) by (le))",
          "legendFormat": "context chars p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_context_chars_bucket[5m])) by (le))",
          "legendFormat": "context chars p95",
          "refId": "B"
        }
      ],
      "title": "RAG — Context Size per Request (chars)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 24 },
      "id": 11,
      "targets": [
        {
          "expr": "sum(rate(rag_requests_total[1m])) by (status)",
          "legendFormat": "status={{status}}",
          "refId": "A"
        }
      ],
      "title": "RAG — Request Rate by Status",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "🚨 SLO Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "green", "index": 0, "text": "OK" }, "1": { "color": "red", "index": 1, "text": "BREACH" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 32 },
      "id": 12,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "textMode": "value_and_name", "colorMode": "background" },
      "targets": [
        {
          "expr": "(\n  sum(rate(gateway_requests_total{status=~\"5..\"}[5m]))\n  /\n  sum(rate(gateway_requests_total[5m]))\n) > bool 0.005",
          "legendFormat": "Availability SLO Breach",
          "refId": "A"
        }
      ],
      "title": "Availability SLO (>99.5%)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "green", "index": 0, "text": "OK" }, "1": { "color": "red", "index": 1, "text": "BREACH" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 32 },
      "id": 13,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "textMode": "value_and_name", "colorMode": "background" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(gateway_request_duration_seconds_bucket[5m])) by (le)) > bool 1.2",
          "legendFormat": "Latency SLO Breach",
          "refId": "A"
        }
      ],
      "title": "Latency SLO (p95 ≤ 1200ms)",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["meridian", "slo", "rag", "model-server"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Meridian Platform — On-Call Dashboard",
  "uid": "meridian-oncall-v1",
  "version": 1
}
